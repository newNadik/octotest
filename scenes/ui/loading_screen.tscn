[sub_resource type="Shader" id="Shader_sticker_shadow"]
code = "shader_type canvas_item;

uniform vec4 shadow_color : source_color = vec4(0.015, 0.082, 0.180, 0.42);
uniform vec2 shadow_offset = vec2(5.0, 8.0);
uniform float blur_radius = 9.5;
uniform float ambient_strength : hint_range(0.0, 1.0) = 0.75;
uniform float edge_softness : hint_range(0.0, 0.2) = 0.06;

void fragment() {
	vec4 base = texture(TEXTURE, UV);
	vec2 texel = TEXTURE_PIXEL_SIZE;
	vec2 offset_uv = UV - shadow_offset * texel;

	float ambient_near = 0.0;
	ambient_near += texture(TEXTURE, UV + vec2(-blur_radius, -blur_radius) * texel).a * 0.08;
	ambient_near += texture(TEXTURE, UV + vec2(0.0, -blur_radius) * texel).a * 0.12;
	ambient_near += texture(TEXTURE, UV + vec2(blur_radius, -blur_radius) * texel).a * 0.08;
	ambient_near += texture(TEXTURE, UV + vec2(-blur_radius, 0.0) * texel).a * 0.12;
	ambient_near += texture(TEXTURE, UV).a * 0.20;
	ambient_near += texture(TEXTURE, UV + vec2(blur_radius, 0.0) * texel).a * 0.12;
	ambient_near += texture(TEXTURE, UV + vec2(-blur_radius, blur_radius) * texel).a * 0.08;
	ambient_near += texture(TEXTURE, UV + vec2(0.0, blur_radius) * texel).a * 0.12;
	ambient_near += texture(TEXTURE, UV + vec2(blur_radius, blur_radius) * texel).a * 0.08;

	float wide_radius = blur_radius * 1.9;
	float ambient_wide = 0.0;
	ambient_wide += texture(TEXTURE, UV + vec2(-wide_radius, -wide_radius) * texel).a * 0.08;
	ambient_wide += texture(TEXTURE, UV + vec2(0.0, -wide_radius) * texel).a * 0.12;
	ambient_wide += texture(TEXTURE, UV + vec2(wide_radius, -wide_radius) * texel).a * 0.08;
	ambient_wide += texture(TEXTURE, UV + vec2(-wide_radius, 0.0) * texel).a * 0.12;
	ambient_wide += texture(TEXTURE, UV).a * 0.20;
	ambient_wide += texture(TEXTURE, UV + vec2(wide_radius, 0.0) * texel).a * 0.12;
	ambient_wide += texture(TEXTURE, UV + vec2(-wide_radius, wide_radius) * texel).a * 0.08;
	ambient_wide += texture(TEXTURE, UV + vec2(0.0, wide_radius) * texel).a * 0.12;
	ambient_wide += texture(TEXTURE, UV + vec2(wide_radius, wide_radius) * texel).a * 0.08;
	float ambient = mix(ambient_near, ambient_wide, 0.45);

	float directional_near = 0.0;
	directional_near += texture(TEXTURE, offset_uv + vec2(-blur_radius, -blur_radius) * texel).a * 0.08;
	directional_near += texture(TEXTURE, offset_uv + vec2(0.0, -blur_radius) * texel).a * 0.12;
	directional_near += texture(TEXTURE, offset_uv + vec2(blur_radius, -blur_radius) * texel).a * 0.08;
	directional_near += texture(TEXTURE, offset_uv + vec2(-blur_radius, 0.0) * texel).a * 0.12;
	directional_near += texture(TEXTURE, offset_uv).a * 0.20;
	directional_near += texture(TEXTURE, offset_uv + vec2(blur_radius, 0.0) * texel).a * 0.12;
	directional_near += texture(TEXTURE, offset_uv + vec2(-blur_radius, blur_radius) * texel).a * 0.08;
	directional_near += texture(TEXTURE, offset_uv + vec2(0.0, blur_radius) * texel).a * 0.12;
	directional_near += texture(TEXTURE, offset_uv + vec2(blur_radius, blur_radius) * texel).a * 0.08;

	float directional_wide = 0.0;
	directional_wide += texture(TEXTURE, offset_uv + vec2(-wide_radius, -wide_radius) * texel).a * 0.08;
	directional_wide += texture(TEXTURE, offset_uv + vec2(0.0, -wide_radius) * texel).a * 0.12;
	directional_wide += texture(TEXTURE, offset_uv + vec2(wide_radius, -wide_radius) * texel).a * 0.08;
	directional_wide += texture(TEXTURE, offset_uv + vec2(-wide_radius, 0.0) * texel).a * 0.12;
	directional_wide += texture(TEXTURE, offset_uv).a * 0.20;
	directional_wide += texture(TEXTURE, offset_uv + vec2(wide_radius, 0.0) * texel).a * 0.12;
	directional_wide += texture(TEXTURE, offset_uv + vec2(-wide_radius, wide_radius) * texel).a * 0.08;
	directional_wide += texture(TEXTURE, offset_uv + vec2(0.0, wide_radius) * texel).a * 0.12;
	directional_wide += texture(TEXTURE, offset_uv + vec2(wide_radius, wide_radius) * texel).a * 0.08;
	float directional = mix(directional_near, directional_wide, 0.35);

	float shadow_alpha = mix(directional, ambient, ambient_strength);
	float base_alpha = smoothstep(0.0, edge_softness, base.a);
	float visible_shadow = shadow_alpha * shadow_color.a * (1.0 - base_alpha);
	vec3 rgb = mix(shadow_color.rgb, base.rgb, base_alpha);
	COLOR = vec4(rgb, max(base_alpha, visible_shadow));
}
"

