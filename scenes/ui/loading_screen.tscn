[sub_resource type="Shader" id="Shader_8ln24"]
code = "shader_type canvas_item;
render_mode unshaded;

uniform sampler2D screen_tex : hint_screen_texture, filter_linear_mipmap;
uniform float vignette_strength : hint_range(0.0, 0.35) = 0.12;
uniform float scanline_strength : hint_range(0.0, 0.2) = 0.01;
uniform float glare_strength : hint_range(0.0, 0.4) = 0.2;
uniform vec2 reflection_offset = vec2(0.0, 0.0);

void fragment() {
	vec2 uv = SCREEN_UV;
	vec4 src = texture(screen_tex, uv);

	vec2 centered = uv - vec2(0.5);
	float vignette = 1.0 - smoothstep(0.22, 0.8, length(centered)) * vignette_strength;

	float y_px = uv.y / SCREEN_PIXEL_SIZE.y;
	float line_wave = sin(y_px * 0.85) * 0.5 + 0.5;
	float scanline = 1.0 - scanline_strength * (1.0 - line_wave);

	vec2 glare_uv = uv + reflection_offset;
	float band = smoothstep(0.32, 0.0, abs(glare_uv.y - 0.2));
	float diagonal = smoothstep(-0.25, 0.95, glare_uv.x + glare_uv.y * 0.35);
	float glare = band * diagonal * glare_strength;

	vec3 tinted = src.rgb * vec3(0.982, 0.993, 1.008);
	vec3 out_rgb = tinted * vignette * scanline + vec3(glare * 0.75, glare * 0.9, glare * 1.1);
	COLOR = vec4(out_rgb, 1.0);
}
"

