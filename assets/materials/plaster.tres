[sub_resource type="Shader" id="Shader_plaster_lower_band"]
code = "shader_type spatial;
render_mode cull_back;

uniform vec4 tint_color : source_color = vec4(0.18144298, 0.3341242, 0.430378, 1.0);
uniform float global_floor_y = 0.0;
uniform float band_height = 1.5;
uniform float roughness = 0.5;
varying float world_y;

void vertex() {
	world_y = (MODEL_MATRIX * vec4(VERTEX, 1.0)).y;
}

void fragment() {
	if (world_y > global_floor_y + band_height) {
		discard;
	}
	ALBEDO = tint_color.rgb;
	ROUGHNESS = roughness;
	METALLIC = 0.0;
}
"

